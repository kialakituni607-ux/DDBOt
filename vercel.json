{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps --no-audit --no-fund --ignore-engines --registry https://registry.npmjs.org",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "headers": [
    {
      "source": "/bots/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/bots/(.*)",
      "destination": "/api/blocked"
    },
    {
      "source": "/((?!static|assets|js|favicon|manifest|sw\\.js|offline\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
