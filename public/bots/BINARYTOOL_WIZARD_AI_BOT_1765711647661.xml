<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="wiz_stake">Stake</variable>
    <variable id="wiz_init_stake">InitialStake</variable>
    <variable id="wiz_profit">TargetProfit</variable>
    <variable id="wiz_loss">StopLoss</variable>
    <variable id="wiz_martingale">Martingale</variable>
  </variables>
  <block type="trade_definition" id="wiz_trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="wiz_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ10V</field>
        <next>
          <block type="trade_definition_tradetype" id="wiz_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="wiz_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="wiz_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="wiz_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="wiz_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="wiz_before" x="0" y="460">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="purchase" id="wiz_purchase">
        <field name="PURCHASE_LIST">even</field>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="wiz_after" x="0" y="600">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="wiz_if_win">
        <value name="IF0">
          <block type="contract_check_result" id="wiz_check_win">
            <field name="RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="wiz_reset_stake">
            <field name="VAR" id="wiz_stake">Stake</field>
            <value name="VALUE">
              <block type="variables_get" id="wiz_get_init">
                <field name="VAR" id="wiz_init_stake">InitialStake</field>
              </block>
            </value>
            <next>
              <block type="notify" id="wiz_win_notify">
                <field name="NOTIFICATION_TYPE">success</field>
                <value name="MESSAGE">
                  <block type="text" id="wiz_win_msg">
                    <field name="TEXT">Wizard AI: Win! Stake reset.</field>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="wiz_if_loss">
            <value name="IF0">
              <block type="contract_check_result" id="wiz_check_loss">
                <field name="RESULT">loss</field>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="wiz_martingale_stake">
                <field name="VAR" id="wiz_stake">Stake</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="wiz_stake_multiply">
                    <field name="OP">MULTIPLY</field>
                    <value name="A">
                      <block type="variables_get" id="wiz_get_stake">
                        <field name="VAR" id="wiz_stake">Stake</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number" id="wiz_mult_num">
                        <field name="NUM">2</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="notify" id="wiz_loss_notify">
                    <field name="NOTIFICATION_TYPE">error</field>
                    <value name="MESSAGE">
                      <block type="text" id="wiz_loss_msg">
                        <field name="TEXT">Wizard AI: Loss. Martingale applied.</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
