<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="eo_stake">Stake</variable>
    <variable id="eo_init">InitialStake</variable>
    <variable id="eo_count">LossCount</variable>
    <variable id="eo_martingale">Martingale</variable>
  </variables>
  <block type="trade_definition" id="eo_trade_def" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="eo_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">R_100</field>
        <next>
          <block type="trade_definition_tradetype" id="eo_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="eo_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="eo_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="eo_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="eo_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
  <block type="before_purchase" id="eo_before" x="0" y="460">
    <statement name="BEFOREPURCHASE_STACK">
      <block type="purchase" id="eo_purchase">
        <field name="PURCHASE_LIST">even</field>
      </block>
    </statement>
  </block>
  <block type="after_purchase" id="eo_after" x="0" y="600">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="eo_if_win">
        <value name="IF0">
          <block type="contract_check_result" id="eo_check_win">
            <field name="RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="eo_reset_count">
            <field name="VAR" id="eo_count">LossCount</field>
            <value name="VALUE">
              <block type="math_number" id="eo_zero">
                <field name="NUM">0</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="eo_reset_stake">
                <field name="VAR" id="eo_stake">Stake</field>
                <value name="VALUE">
                  <block type="variables_get" id="eo_get_init">
                    <field name="VAR" id="eo_init">InitialStake</field>
                  </block>
                </value>
                <next>
                  <block type="notify" id="eo_win_notify">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <value name="MESSAGE">
                      <block type="text" id="eo_win_msg">
                        <field name="TEXT">Even &amp; Odd AI: Win! Stake reset.</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="controls_if" id="eo_if_loss">
            <value name="IF0">
              <block type="contract_check_result" id="eo_check_loss">
                <field name="RESULT">loss</field>
              </block>
            </value>
            <statement name="DO0">
              <block type="math_change" id="eo_inc_count">
                <field name="VAR" id="eo_count">LossCount</field>
                <value name="DELTA">
                  <block type="math_number" id="eo_delta">
                    <field name="NUM">1</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="eo_martingale_stake">
                    <field name="VAR" id="eo_stake">Stake</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="eo_stake_multiply">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <block type="variables_get" id="eo_get_stake">
                            <field name="VAR" id="eo_stake">Stake</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="eo_mult_num">
                            <field name="NUM">2</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="notify" id="eo_loss_notify">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <value name="MESSAGE">
                          <block type="text" id="eo_loss_msg">
                            <field name="TEXT">Even &amp; Odd AI: Loss. Martingale applied.</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
